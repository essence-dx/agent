# DX Agents Environment Variables - DX Agent v0.8 compatible
#
# Copy this file to `.env` and fill in your local values.
# Never commit `.env` or any real secrets.
#
# DX Agents keeps DX_AGENTS_* aliases for fork branding and migration, while
# the latest upstream config loader also supports the DX Agent v0.8 schema
# mirror:
#
#   DX_AGENT_<dotted_path_with_double_underscores>=<value>
#
# The tail mirrors the TOML config path 1:1. `__` is the path separator
# (`.` in TOML). Single `_` is either a snake-case joiner inside a field name
# (`api_key` -> the schema's kebab `api-key`) or a literal char inside an alias
# key (`prod_v2`).

# Bootstrap
# DX_AGENTS_CONFIG_DIR=/path/to/.dx-agents
# DX_AGENTS_WORKSPACE=/path/to/workspace
# DX_AGENT_CONFIG_DIR=/path/to/.dx_agent
# DX_AGENT_DATA_DIR=/path/to/data
# DX_AGENT_WORKSPACE=/path/to/legacy/workspace  # deprecated upstream alias

# Self-update release source (owner/repo or GitHub URL)
# DX_AGENTS_UPDATE_REPO=millercarla211-ctrl/dx-agents

# Provider/model compatibility aliases
# DX_AGENTS_PROVIDER=groq
# DX_AGENTS_MODEL=llama-3.3-70b-versatile
# DX_AGENTS_API_KEY=your-api-key-here
# DX_AGENT_PROVIDER=groq
# DX_AGENT_MODEL=llama-3.3-70b-versatile
# DX_AGENT_API_KEY=your-api-key-here
# API_KEY=your-api-key-here

# Schema-mirror examples
# DX_AGENT_providers__models__anthropic__default__api_key=sk-ant-...
# DX_AGENT_providers__models__openrouter__prod_v2__model=anthropic/claude-sonnet-4-6
# DX_AGENT_providers__models__openrouter__prod_v2__api_key=sk-or-...
# DX_AGENT_channels__matrix__enabled=true
# DX_AGENT_channels__matrix__homeserver=https://matrix.example.org
# DX_AGENT_gateway__request_timeout_secs=120
# DX_AGENT_gateway__long_running_request_timeout_secs=900
# DX_AGENT_channels__whatsapp__default__app_secret=...
# DX_AGENT_channels__linq__default__signing_secret=...
# DX_AGENT_channels__nextcloud_talk__default__webhook_secret=...
# DX_AGENT_storage__qdrant__default__url=https://qdrant.example.com
# DX_AGENT_storage__qdrant__default__collection=zeroclaw
# DX_AGENT_storage__qdrant__default__api_key=...

# Provider-specific keys and auth tokens
# GROQ_API_KEY=gsk_...
# OPENROUTER_API_KEY=sk-or-v1-...
# ANTHROPIC_OAUTH_TOKEN=...
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
# GOOGLE_API_KEY=...
# VENICE_API_KEY=...
# MISTRAL_API_KEY=...
# DEEPSEEK_API_KEY=...
# XAI_API_KEY=...
# TOGETHER_API_KEY=...
# FIREWORKS_API_KEY=...
# PERPLEXITY_API_KEY=...
# COHERE_API_KEY=...
# MOONSHOT_API_KEY=...
# GLM_API_KEY=...
# ZAI_API_KEY=...
# MINIMAX_OAUTH_TOKEN=...
# MINIMAX_API_KEY=...
# MINIMAX_OAUTH_REFRESH_TOKEN=...
# MINIMAX_OAUTH_REGION=global
# QIANFAN_API_KEY=...
# DASHSCOPE_API_KEY=...
# SYNTHETIC_API_KEY=...
# OPENCODE_API_KEY=...
# OPENCODE_GO_API_KEY=...
# VERCEL_API_KEY=...
# CLOUDFLARE_API_KEY=...

# Gateway
# DX_AGENTS_GATEWAY_PORT=3000
# DX_AGENTS_GATEWAY_HOST=127.0.0.1
# DX_AGENTS_ALLOW_PUBLIC_BIND=false
# DX_AGENTS_REQUIRE_PAIRING=true
# DX_AGENTS_GATEWAY_TOKEN=...

# ACP bridge
# DX_AGENTS_ACP_BRIDGE_TOKEN=...
# DX_AGENTS_ACP_PAIRING_CODE=...

# Proxy
# DX_AGENTS_PROXY_ENABLED=false
# DX_AGENTS_HTTP_PROXY=http://proxy.example.com:8080
# DX_AGENTS_HTTPS_PROXY=http://proxy.example.com:8080
# DX_AGENTS_ALL_PROXY=socks5://proxy.example.com:1080
# DX_AGENTS_NO_PROXY=localhost,127.0.0.1
# DX_AGENTS_PROXY_SCOPE=zeroclaw
# DX_AGENTS_PROXY_SERVICES=openai,anthropic,groq

# Optional integrations
# PUSHOVER_TOKEN=your-pushover-app-token
# PUSHOVER_USER_KEY=your-pushover-user-key
# BRAVE_API_KEY=your-brave-search-api-key
# SEARXNG_INSTANCE_URL=https://searx.example.com

# Docker Compose
# HOST_PORT=3000
